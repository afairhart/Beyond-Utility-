rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Any authenticated user can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;

      // Admins can read/list/write any user profile
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";

      // Allow authenticated users to create their own profile
      // (used for first-user bootstrap and admin-created accounts)
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role in ['admin', 'partner'];

      // Allow users to update their own login activity fields
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt', 'loginCount']);
    }

    // Allow authenticated users to list the users collection
    // (needed for the first-user bootstrap check)
    match /users/{document=**} {
      allow list: if request.auth != null;
    }

    // LinkedIn connections — admin read/write only
    match /linkedinConnections/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Settings (API keys, etc.) — admin read/write only
    match /settings/{docId} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}
